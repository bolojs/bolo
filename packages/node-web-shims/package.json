{
  "name": "@bolojs/node-web-shims",
  "version": "0.2.0",
  "description": "node:* to Web API shims (crypto, stream, buffer, path, url, events, os, http, worker_threads); usable standalone.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "threads.js": "^0.6.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "pathe": "^2.0.0",
    "unenv": "2.0.0-rc.24"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bolojs/bolo.git",
    "directory": "packages/node-web-shims"
  },
  "homepage": "https://bolojs.dev/docs/api/",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  }
}
