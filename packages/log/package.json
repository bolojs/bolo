    "@logtape/pretty": "^2.2.4"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
