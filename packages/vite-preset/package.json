{
  "name": "@bolojs/vite-preset",
  "version": "0.1.0",
  "description": "Vite preset that wires node:* polyfills and the crossOriginIsolated headers apps embedding bolo need.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bolojs/node-web-shims": "workspace:*",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.10"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bolojs/bolo.git",
    "directory": "packages/vite-preset"
  },
  "homepage": "https://bolojs.dev/docs/getting-started/",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  }
}
