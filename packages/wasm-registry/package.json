{
  "name": "@bolojs/registry",
  "version": "0.2.0",
  "description": "In-browser bundler (rolldown + oxc-transform) with a registerWasmTool() extension seam for bolo.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@bolojs/pm": "workspace:*",
    "@bolojs/fs": "workspace:*",
    "@rolldown/browser": "^1.1.5",
    "oxc-transform": "^0.140.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bolojs/bolo.git",
    "directory": "packages/wasm-registry"
  },
  "homepage": "https://bolojs.dev/docs/api/#extending-bolo",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  }
}
